# Backend configuration (12-factor). Copy to .env; NEVER commit real secrets.
DRCPAY_ENVIRONMENT=local            # local | sandbox | production

# Datastores — leave DATABASE_URL blank to use the in-memory store (good for the demo).
# To use Postgres (start it with `docker compose up` from the repo root):
#   DRCPAY_DATABASE_URL=postgresql+psycopg://drcpay:drcpay@localhost:5432/drcpay
DRCPAY_DATABASE_URL=
DRCPAY_REDIS_URL=redis://localhost:6379/0

# pawaPay — get the base URL + token from pawaPay's docs / your secret store.
# Sandbox first. Production values live ONLY in AWS Secrets Manager, never here.
DRCPAY_PAWAPAY_BASE_URL=
DRCPAY_PAWAPAY_API_TOKEN=
# pawaPay public key (PEM) for verifying signed callbacks; blank disables the webhook.
DRCPAY_PAWAPAY_PUBLIC_KEY=

# USSD shortcode customers dial (placeholder until the aggregator assigns the real one).
# Each merchant's till is appended, e.g. *123*1001#.
DRCPAY_USSD_SHORTCODE=*123#
