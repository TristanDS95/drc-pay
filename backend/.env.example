# Backend configuration (12-factor). Copy to .env; NEVER commit real secrets.
DRCPAY_ENVIRONMENT=local            # local | sandbox | production

# Datastores — leave DATABASE_URL blank to use the in-memory store (good for the demo).
# To use Postgres (start it with `docker compose up` from the repo root):
#   DRCPAY_DATABASE_URL=postgresql+psycopg://drcpay:drcpay@localhost:5432/drcpay
DRCPAY_DATABASE_URL=

# pawaPay — get the base URL + token from pawaPay's docs / your secret store.
# Sandbox first. Production values live ONLY in Railway's dashboard, never here.
DRCPAY_PAWAPAY_BASE_URL=
DRCPAY_PAWAPAY_API_TOKEN=
# pawaPay public key (PEM) for verifying signed callbacks — leave blank; the app auto-fetches it
# from pawaPay when a live rail is configured. Set only to pin a specific key.
DRCPAY_PAWAPAY_PUBLIC_KEY=

# USSD shortcode customers dial (placeholder until the aggregator assigns the real one).
# Each merchant's till is appended, e.g. *123*1001#.
DRCPAY_USSD_SHORTCODE=*123#

# Shared HTTP Basic password gating the Merchant Console + API (username `drcpay`). Blank = no
# gate (local dev only). REQUIRED when DRCPAY_ENVIRONMENT is not `local` — the app refuses to
# boot a deployed environment without it. The real value lives ONLY in the secret store.
DRCPAY_BASIC_AUTH_PASSWORD=

# How often (seconds) the reconciliation sweep polls pawaPay for missed outcomes. Runs only on a
# live rail (never the in-process simulator). Default 300 (5 min).
DRCPAY_RECONCILE_INTERVAL_SECONDS=300
