# Backend configuration (12-factor). Copy to .env; NEVER commit real secrets.
DRCPAY_ENVIRONMENT=local            # local | sandbox | production

# Datastores — leave DATABASE_URL blank to use the in-memory store (good for the demo).
# To use Postgres (start it with `docker compose up` from the repo root):
#   DRCPAY_DATABASE_URL=postgresql+psycopg://drcpay:drcpay@localhost:5432/drcpay
DRCPAY_DATABASE_URL=

# pawaPay — get the base URL + token from pawaPay's docs / your secret store.
# Sandbox first. Production values live ONLY in Railway's dashboard, never here.
DRCPAY_PAWAPAY_BASE_URL=
DRCPAY_PAWAPAY_API_TOKEN=
# pawaPay public key (PEM) for verifying signed callbacks — leave blank; the app auto-fetches it
# from pawaPay when a live rail is configured. Set only to pin a specific key.
DRCPAY_PAWAPAY_PUBLIC_KEY=

# USSD shortcode customers dial (placeholder until the aggregator assigns the real one).
# Each merchant's till is appended, e.g. *123*1001#.
DRCPAY_USSD_SHORTCODE=*123#

# USSD menu language: fr (default — the DRC's primary language) or en.
DRCPAY_USSD_LANG=fr

# Shared secret the USSD aggregator sends in X-USSD-Secret. Blank = check disabled (local/
# sandbox, so the console's dial simulator works). REQUIRED in production — the app refuses
# to boot without it. The real value lives ONLY in the secret store.
DRCPAY_USSD_SHARED_SECRET=

# Shared HTTP Basic password gating the sandbox demo SHELL (console page, docs, /demo/*;
# username `drcpay`). The merchant API itself is gated by per-merchant logins in every
# environment. Blank = no demo gate (local dev / production). REQUIRED in `sandbox` — the
# app refuses to boot without it. The real value lives ONLY in the secret store.
DRCPAY_BASIC_AUTH_PASSWORD=

# How often (seconds) the reconciliation sweep polls pawaPay for missed outcomes. Runs only on a
# live rail (never the in-process simulator). Default 300 (5 min).
DRCPAY_RECONCILE_INTERVAL_SECONDS=300

# Bootstrap staff (admin) account, created-or-updated on every deploy in EVERY environment.
# This is how a `production` deploy gets its first staff account: production seeds no demo data,
# so without this nobody could approve merchant sign-ups there. Set BOTH to enable; blank = off.
# The env var is the source of truth for this account's password — change it here to rotate on the
# next deploy. The real value lives ONLY in the secret store, never in the repo.
DRCPAY_ADMIN_USERNAME=
DRCPAY_ADMIN_PASSWORD=

# The internal Staff Console (approve/reject merchant sign-ups), served at /staff when set.
# Set by the Dockerfile in the deployed image; only needed locally if you want /staff.
DRCPAY_STAFF_DIR=
